{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/U-BDS/nf_xpatial/main/assets/schema_input.json",
    "title": "U-BDS/nf_xpatial pipeline - params.input schema",
    "description": "Schema for the file provided with params.input",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "sample": {
                "type": "string",
                "pattern": "^\\S+$",
                "errorMessage": "Sample name must be provided and cannot contain spaces",
                "meta": ["id"]
            },
            "xenium": {
                "type": "string",
                "format": "directory-path",
                "exists": true,
                "pattern": "^\\S+$",
                "errorMessage": "Xenium input file must be provided and cannot contain spaces"
            },
            "metadata": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^\\S+$",
                "errorMessage": "Metadata file must be provided and cannot contain spaces"
            },
            "manual_annotation": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^\\S+$"
            }
        },
        "required": ["sample", "xenium", "metadata"]
    }
}
