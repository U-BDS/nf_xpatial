        }
    }

    if (!params.skip_post_cell_area_qc) {
        if (!params.skip_post_area_histogram_plot) {
            process {
                withName: '.*SPATIAL_QC_POSTFILTER.*:QC_HISTOGRAM_PLOT' {
                    publishDir = [
                        path: { "${params.outdir}/compiled/filtered/qc/cell_area_qc" },
                        mode: params.publish_dir_mode,
                        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                    ]
                }
            }
        }

        process {
            withName: '.*SPATIAL_QC_POSTFILTER.*:CALCULATE_OUTLIERS' {
