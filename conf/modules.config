            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}

process{
    withName: '.*:MANUAL_ANNOTATION_IMG_DIM_PLOT' {
        ext.args = {
            [
                '--group_by Tissue_annotation'
            ].join(' ').trim()
        }
        publishDir = [
            path: { "${params.outdir}/compiled/manual_annotations/qc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}

process {
    withName: '.*:COMPILE_MANUAL_ANNOTATIONS' {
        publishDir = [ 
            enabled: false
        ]
    }
}

