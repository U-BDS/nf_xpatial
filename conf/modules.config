/********************
 * FILTERING MODULE *
 ********************/

if (!params.skip_filtering) {

    process{
        withName: '.*:FILTER_XENIUM_OBJ' {
            ext.prefix = { "${meta.id}.filtered" }
            ext.args = {
                [
                    params.filter_features ? "--filter_features ${params.filter_features}" : '',
                    params.skip_column_removal ? '--skip_column_removal' : '',
                    params.columns_to_remove ? "--columns ${params.columns_to_remove}" : '',
                    params.skip_percentile_filtering ? '--skip_percentile_filter' : '',
                    params.min_percentile ? "--min_percentile ${params.min_percentile}" : '',
                    params.max_percentile ? "--max_percentile ${params.max_percentile}" : '',
                    params.skip_nFeature_filtering ? '--skip_nFeature_filter' : '',
                    params.min_nFeature ? "--min_nFeature ${params.min_nFeature}" : '',
                    params.max_nFeature ? "--max_nFeature ${params.max_nFeature}" : '',
                    params.skip_nCount_filtering ? '--skip_nCount_filter' : '',
                    params.min_nCount ? "--min_nCount ${params.min_nCount}" : '',
                    params.max_nCount ? "--max_nCount ${params.max_nCount}" : '',
                    params.skip_cell_area_filtering ? '--skip_cell_area_filter' : '',
                    params.min_cell_area ? "--min_cell_area ${params.min_cell_area}" : '',
                    params.max_cell_area ? "--max_cell_area ${params.max_cell_area}" : ''
                ].join(' ').trim()
            }
            publishDir = [
                path: { "${params.outdir}/${meta.id}/filtered/" },
                mode: params.publish_dir_mode,
                saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
            ]
        }
    }
}

