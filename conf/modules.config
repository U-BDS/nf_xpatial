            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}

/************************
 * BANKSY CLUSTERING    *
 ************************/

process {
    withName: '.*:BANKSY:ADD_TISSUE_COORDS' {
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:BANKSY:MERGE_XENIUM_OBJECTS' {
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:BANKSY:CONVERT_SEURAT_TO_SPE' {
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:BANKSY:STAGGER_SPATIAL_COORDS' {
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:BANKSY:COMPUTE_BANKSY_MATRIX' {
        ext.args = {
            [
                ${params.use_agf_BANKSY} ? '--agf' : ''
            ].join(' ').trim()
        }
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:BANKSY:COMPUTE_BANKSY_PCA' {
        ext.args = {
            [
                ${params.use_agf_BANKSY} ? '--agf' : ''
            ].join(' ').trim()
        }
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:BANKSY:RUN_HARMONY_BANKSY' {
        ext.args = {
            [
                "--max_iter ${params.max_iter_BANKSY}",
            ].join(' ').trim()
        }
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:BANKSY:RUN_UMAP_BANKSY' {
        ext.args = {
            [
                '--use_harmony',
            ].join(' ').trim()
        }
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:BANKSY:CLUSTER_BANKSY' {
        ext.args = {
            [
                "--param_str BSKY_AGF1_L${lambda}_k${k_geom}_PC${nPCs}_R${res}",
            ].join(' ').trim()
        }
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:BANKSY:EXTRACT_BANKSY_CLUSTER_METADATA' {
        ext.prefix = { "${meta.id}.banksy_k${k_geom}_l${lambda}_pc${nPCs}_res${res}" }
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:BANKSY:EXTRACT_PARAMS' {
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:BANKSY:EXTRACT_XE_METADATA' {
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:BANKSY:EXTRACT_REDUCED_DIMS' {
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:BANKSY:MERGE_CLUSTER_TSV' {
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:BANKSY:ADD_BANKSY_TO_SEURAT' {
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:BANKSY:QC_BANKSY_PLOTS' {
        publishDir = [
            path: { "${params.outdir}/compiled/banksy/qc/" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}
