        process {
            withName: '.*SPATIAL_QC_POSTFILTER.*:COMPILE_OUTLIER_DF' {
                publishDir = [ 
                    enabled: false
                ]
            }
        }

        if (!params.skip_post_area_box_plot) {
            process {
                withName: '.*SPATIAL_QC_POSTFILTER.*:QC_BOX_PLOT' {
                    publishDir = [
                        path: { "${params.outdir}/compiled/filtered/qc/cell_area_qc" },
                        mode: params.publish_dir_mode,
                        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                    ]
                }
            }
        }

        if (!params.skip_post_area_overlap_histogram_plot) {
            process {
                withName: '.*SPATIAL_QC_POSTFILTER.*:QC_OVERLAPPING_HISTOGRAM_PLOT' {
                    publishDir = [
                        path: { "${params.outdir}/compiled/filtered/qc/cell_area_qc" },
                        mode: params.publish_dir_mode,
                        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                    ]
                }
            }
        }
    }
}

/********************
* FILTERING MODULE *
********************/

if (!params.skip_filtering) {

    process{
        withName: '.*:FILTER_XENIUM_OBJ' {
            ext.prefix = { "${meta.id}.filtered" }
            ext.args = {
                [
                    params.filter_features ? "--filter_features ${params.filter_features}" : '',
                    params.skip_column_removal ? '--skip_column_removal' : '',
                    params.columns_to_remove ? "--columns ${params.columns_to_remove}" : '',
                    params.skip_percentile_filtering ? '--skip_percentile_filter' : '',
                    params.min_percentile ? "--min_percentile ${params.min_percentile}" : '',
                    params.max_percentile ? "--max_percentile ${params.max_percentile}" : '',
                    params.skip_nFeature_filtering ? '--skip_nFeature_filter' : '',
                    params.min_nFeature ? "--min_nFeature ${params.min_nFeature}" : '',
                    params.max_nFeature ? "--max_nFeature ${params.max_nFeature}" : '',
                    params.skip_nCount_filtering ? '--skip_nCount_filter' : '',
                    params.min_nCount ? "--min_nCount ${params.min_nCount}" : '',
                    params.max_nCount ? "--max_nCount ${params.max_nCount}" : '',
                    params.skip_cell_area_filtering ? '--skip_cell_area_filter' : '',
                    params.min_cell_area ? "--min_cell_area ${params.min_cell_area}" : '',
                    params.max_cell_area ? "--max_cell_area ${params.max_cell_area}" : ''
                ].join(' ').trim()
            }
            publishDir = [
                path: { "${params.outdir}/${meta.id}/filtered/" },
                mode: params.publish_dir_mode,
                saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
            ]
        }
    }
}

/*****************************
 * NORMALIZATION SUBWORKFLOW *
 *****************************/

 process{
    withName: '.*:NORMALIZE_LOG' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/normalized/log/" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}

process {
    withName: '.*:COMPILE_LOG_OBJECTS' {
        publishDir = [ 
            enabled: false
        ]
    }
}

process{
    withName: '.*:NORMALIZE_AREA' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/normalized/area/" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}

process {
    withName: '.*:COMPILE_AREA_OBJECTS' {
        publishDir = [ 
            enabled: false
        ]
    }
}

if (!params.skip_qc) {
    if (!params.skip_norm_nfeature) {
        process {
            withName: '.*:NORMALIZE_DATA:QC_IFP_NORM_NFEATURE' {
                ext.prefix = { "${meta.id}.qc_nfeature" }
                ext.args = {
                    [
                        '--features "nFeature_Xenium"',
                        ${meta.normalization} == 'area' ? '--assay "AreaNorm"' : '--assay "Xenium"'
                    ].join(' ').trim()
                }
                publishDir = [
                    path: { "${params.outdir}/compiled/normalized/${meta.normalization}/qc" },
                    mode: params.publish_dir_mode,
                    saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                ]
            }
        }
    }

    if (!params.skip_norm_ncount) {
        process {
            withName: '.*:NORMALIZE_DATA:QC_IFP_NORM_NCOUNT' {
                ext.prefix = { "${meta.id}.qc_ncount" }
                ext.args = {
                    [
                        '--features "nCount_Xenium"',
                        ${meta.normalization} == 'area' ? '--assay "AreaNorm"' : '--assay "Xenium"'
                    ].join(' ').trim()
                }
                publishDir = [
                    path: { "${params.outdir}/compiled/normalized/${meta.normalization}/qc" },
                    mode: params.publish_dir_mode,
                    saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                ]
            }
        }
    }
}

/*******************************
 * CLUSTER HARMONY SUBWORKFLOW *
 *******************************/

process {
    withName: '.*:CLUSTER_HARMONY:SCALE_DATA' {
        publishDir = [ 
            enabled: false
        ]
    }
}

process {
    withName: '.*:CLUSTER_HARMONY:RUN_PCA' {
        publishDir = [ 
            enabled: false
        ]
    }
}

process{
    withName: '.*:CLUSTER_HARMONY:QC_ELBOW_PLOT' {
        ext.prefix = { "${meta.id}.${meta.normalization}" }
        publishDir = [
            path: { "${params.outdir}/compiled/Harmony/${meta.normalization}/qc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}

process {
    withName: '.*:CLUSTER_HARMONY:RUN_HARMONY' {
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:CLUSTER_HARMONY:RUN_UMAP' {
        ext.prefix = {"${meta.id}.d${meta.dim}"}
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:CLUSTER_HARMONY:FIND_NEIGHBORS' {
        ext.prefix = {"${meta.id}.d${meta.dim}"}
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:CLUSTER_HARMONY:FIND_CLUSTERS' {
        ext.prefix = {"${meta.id}.d${meta.dim}_r${meta.res}"}
        publishDir = [
            path: { "${params.outdir}/compiled/Harmony/${meta.normalization}/" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}

if (!params.skip_tsne_plot) {
    process {
        withName: '.*:CLUSTER_HARMONY:RUN_TSNE' {
            ext.prefix = {"${meta.id}.dim${meta.dim}"}
            publishDir = [
                path: { "${params.outdir}/compiled/Harmony/${meta.normalization}/" },
                mode: params.publish_dir_mode,
                saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
            ]
        }
    }

    if (!params.skip_qc) {
        process {
            withName: '.*:CLUSTER_HARMONY:TSNE_DIM_PLOT' {
                ext.prefix = {"${meta.id}.d${meta.dim}_r${meta.res}_tsne"}
                ext.args = {
                    '--embedding "tsne"'
                }
                publishDir = [
                    path: { "${params.outdir}/compiled/Harmony/${meta.normalization}/qc/tsne_dim_plot" },
                    mode: params.publish_dir_mode,
                    saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                ]
            }
        }
    }
}

/************************
 * BANKSY CLUSTERING    *
 ************************/

process {
    withName: '.*:BANKSY:CONVERT_SEURAT_TO_SPE' {
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:BANKSY:STAGGER_SPATIAL_COORDS' {
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:BANKSY:COMPUTE_BANKSY_MATRIX' {
        ext.prefix = {"${meta.id}_AGF${meta.agf}_k${meta.k_geom}"}
        ext.args = {
            [
                '--agf'
            ].join(' ').trim()
        }
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:BANKSY:COMPUTE_BANKSY_PCA' {
        ext.prefix = {"${meta.id}_AGF${meta.agf}_L${meta.lambda}_k${meta.k_geom}"}
        ext.args = {
            [
                params.use_agf_BANKSY ? '--agf' : ''
            ].join(' ').trim()
        }
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:BANKSY:RUN_HARMONY_BANKSY' {
        ext.prefix = {"${meta.id}_AGF${meta.agf}_L${meta.lambda}_k${meta.k_geom}_PC${meta.nPCs}"}
        ext.args = {
            [
                "--max_iter ${params.max_iter_BANKSY}",
            ].join(' ').trim()
        }
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:BANKSY:RUN_UMAP_BANKSY' {
        ext.prefix = {"${meta.id}_AGF${meta.agf}_L${meta.lambda}_k${meta.k_geom}_PC${meta.nPCs}"}
        ext.args = {
            [
                '--use_harmony',
                params.use_agf_BANKSY ? '--agf' : ''
            ].join(' ').trim()
        }
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:BANKSY:CLUSTER_BANKSY' {
        ext.prefix = {"${meta.id}_AGF${meta.agf}_L${meta.lambda}_k${meta.k_geom}_PC${meta.nPCs}_R${meta.res}"}
        ext.args = {
            [
                '--use_harmony',
                params.use_agf_BANKSY ? '--agf' : '',
                "--param_str BSKY_AGF${meta.agf}_L${meta.lambda}_k${meta.k_geom}_PC${meta.nPCs}_R${meta.res}",
            ].join(' ').trim()
        }
        publishDir = [
            path: { "${params.outdir}/compiled/BANKSY/${meta.normalization}/" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}

/**********************************************
 * MERGE CLUSTERED XENIUM OBJECTS SUBWORKFLOW *
 **********************************************/

process {
    withName: '.*:MERGE_CLUSTERED_XENIUM_OBJECTS:EXTRACT_CLUSTER_METADATA' {
        ext.prefix = { "${meta.clustering_method}" == "BANKSY" ?
                "${meta.id}.AGF${meta.agf}_L${meta.lambda}_k${meta.k_geom}_PC${meta.nPCs}_R${meta.res}" :
                "${meta.id}.d${meta.dim}_r${meta.res}"
        }
        publishDir = [
            path: { "${params.outdir}/compiled/${meta.clustering_method}/${meta.normalization}/cluster_csvs/" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}

process {
    withName: '.*:MERGE_CLUSTERED_XENIUM_OBJECTS:EXTRACT_REDUCED_DIMS' {
        publishDir = [
            path: { "${params.outdir}/compiled/${meta.clustering_method}/${meta.normalization}/reduced_dim_csvs/" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}

process {
    withName: '.*:MERGE_CLUSTERED_XENIUM_OBJECTS:MERGE_CSV' {
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:MERGE_CLUSTERED_XENIUM_OBJECTS:CONNECT_CLUSTERS' {
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:MERGE_CLUSTERED_XENIUM_OBJECTS:ADD_CLUSTER_DATA_TO_SEURAT' {
        publishDir = [
            path: { "${params.outdir}/compiled/" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}

/**************************
 * CLUSTER QC SUBWORKFLOW *
 **************************/

if (!params.skip_qc) {
    if (!params.skip_cluster_umap_plot) {
        process {
            withName: '.*:CLUSTER_QC:UMAP_DIM_PLOT' {
                ext.prefix = { "${meta.clustering_method}" == "BANKSY" ?
                    "${meta.id}.AGF${meta.agf}_L${meta.lambda}_k${meta.k_geom}_PC${meta.nPCs}_R${meta.res}"  :
                    "${meta.id}.d${meta.dim}_r${meta.res}"
                }
                publishDir = [
                    path: { "${params.outdir}/compiled/${meta.clustering_method}/${meta.normalization}/qc/umap_dim_plot" },
                    mode: params.publish_dir_mode,
                    saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                ]
            }
        }
    }

    if (!params.skip_cluster_split_plot) {
        process {
            withName: '.*:CLUSTER_QC:QC_SPLIT_CLUSTER_PLOTS' {
                ext.prefix = { "${meta.clustering_method}" == "BANKSY" ?
                    "${meta.id}.AGF${meta.agf}_L${meta.lambda}_k${meta.k_geom}_PC${meta.nPCs}_R${meta.res}"  :
                    "${meta.id}.d${meta.dim}_r${meta.res}"
                }
                publishDir = [
                    path: { "${params.outdir}/compiled/${meta.clustering_method}/${meta.normalization}/qc/marker_vln_plots" },
                    mode: params.publish_dir_mode,
                    saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                ]
            }
        }
    }

    if (!params.skip_cluster_vln_plot) {
        process {
            withName: '.*:CLUSTER_QC:QC_MARKER_VLN_PLOT' {
                ext.prefix = { "${meta.clustering_method}" == "BANKSY" ?
                    "${meta.id}.l${meta.lambda}_k${meta.k_geom}_PC${meta.nPCs}_res${meta.res}" :
                    "${meta.id}.d${meta.dim}_r${meta.res}"
                }
                publishDir = [
                    path: { "${params.outdir}/compiled/${meta.clustering_method}/${meta.normalization}/qc/vln_plots" },
                    mode: params.publish_dir_mode,
                    saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                ]
            }
        }
    }

    if (!params.skip_cluster_dot_plot) {
        process {
            withName: '.*:CLUSTER_QC:QC_MARKER_DOT_PLOT' {
                ext.prefix = { "${meta.clustering_method}" == "BANKSY" ?
                    "${meta.id}.l${meta.lambda}_k${meta.k_geom}_PC${meta.nPCs}_res${meta.res}" :
                    "${meta.id}.d${meta.dim}_r${meta.res}"
                }
                publishDir = [
                    path: { "${params.outdir}/compiled/${meta.clustering_method}/${meta.normalization}/qc/dot_plots" },
                    mode: params.publish_dir_mode,
                    saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                ]
            }
        }
    }
}
