    if (!params.skip_pre_cell_shape_qc) {
        process {
            withName: '.*SPATIAL_QC_POSTFILTER.*:CLASSIFY_CELL_SHAPE' {
                publishDir = [
                    path: { "${params.outdir}/${meta.id}/filtered/qc/cell_shape_qc/" },
                    mode: params.publish_dir_mode,
                    saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                ]
            }
        }

        if (!params.skip_post_cell_shape_prop_plot) {
            process {
                withName: '.*SPATIAL_QC_POSTFILTER.*:CELL_SHAPE_PLOT' {
                    ext.prefix = { "${meta.id}.cell_shape"}
                    publishDir = [
                        path: { "${params.outdir}/compiled/filtered/qc/cell_shape_qc/" },
                        mode: params.publish_dir_mode,
                        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                    ]
                }
            }
        }

        if (!params.skip_post_cell_segm_prop_plot) {
            process {
                withName: '.*SPATIAL_QC_POSTFILTER.*:CELL_SEGM_PLOT' {
                    ext.prefix = { "${meta.id}.cell_segmentation"}
                    publishDir = [
                        path: { "${params.outdir}/compiled/filtered/qc/cell_shape_qc/" },
                        mode: params.publish_dir_mode,
                        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                    ]
                }
            }
        }
    }

    /**************************
    * GENERAL_QC SUBWORKFLOW *
    **************************/

    if (!params.skip_pre_general_qc) {
        // SPATIAL_QC_PREFILTER MODULE 
        process {
            withName: '.*SPATIAL_QC_PREFILTER.*:COMPILE_OBJECTS' {
                publishDir = [ 
                    enabled: false
                ]
            }
        }

        if (!params.skip_pre_general_dim_plot) {
            process {
                withName: '.*SPATIAL_QC_PREFILTER.*:GENERAL_QC:QC_IMAGE_DIM_PLOT' {
                    //ext.prefix = "${meta.id}.image_dim_plot"
                    ext.args = {
                        [
                            '--group_by BiologicalGroup'
                        ].join(' ').trim()
                    }
                    publishDir = [
                        path: { "${params.outdir}/compiled/raw_data/qc" },
                        mode: params.publish_dir_mode,
                        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                    ]
                }
            }
        }

        if (!params.skip_pre_general_vln_plot) {
            process {
                withName: '.*SPATIAL_QC_PREFILTER.*:GENERAL_QC:QC_VLN_PLOT' {
                    ext.args = {
                        [
                            '--features "nCount_Xenium,nFeature_Xenium"',
                            '--ncols_vln 2'
                        ].join(' ').trim()
                    }
                    publishDir = [
                        path: { "${params.outdir}/compiled/raw_data/qc" },
                        mode: params.publish_dir_mode,
                        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                    ]
                }
            }
        }

        if (!params.skip_pre_general_scatter_plot) {
            process {
                withName: '.*SPATIAL_QC_PREFILTER.*:GENERAL_QC:QC_FEATURE_SCATTER_PLOT' {
                    ext.args = {
                        [
                            '--feature1 nCount_Xenium',
                            '--feature2 nFeature_Xenium',
                        ].join(' ').trim()
                    }
                    publishDir = [
                        path: { "${params.outdir}/compiled/raw_data/qc" },
                        mode: params.publish_dir_mode,
                        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                    ]
                }
            }
        }

        if (!params.skip_pre_general_nfeature_plot) {
            process {
                withName: '.*SPATIAL_QC_PREFILTER.*:GENERAL_QC:QC_IFP_NFEATURE' {
                    ext.prefix = { "${meta.id}.qc_nfeature" }
                    ext.args = {
                        [
                            '--features "nFeature_Xenium"'
                        ].join(' ').trim()
                    }
                    publishDir = [
                        path: { "${params.outdir}/compiled/raw_data/qc" },
                        mode: params.publish_dir_mode,
                        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                    ]
                }
            }
        }

        if (!params.skip_pre_general_ncount_plot) {
            process {
                withName: '.*SPATIAL_QC_PREFILTER.*:GENERAL_QC:QC_IFP_NCOUNT' {
                    ext.prefix = { "${meta.id}.qc_ncount" }
                    ext.args = {
                        [
                            '--features "nCount_Xenium"'
                        ].join(' ').trim()
                    }
                    publishDir = [
                        path: { "${params.outdir}/compiled/raw_data/qc" },
                        mode: params.publish_dir_mode,
                        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                    ]
                }
            }
        }
    }

    if (!params.skip_post_general_qc) {
        // SPATIAL_QC_POSTFILTER MODULE
        process {
            withName: '.*SPATIAL_QC_POSTFILTER.*:COMPILE_OBJECTS' {
                publishDir = [ 
                    enabled: false
                ]
            }
        }

        if (!params.skip_post_general_dim_plot) {
            process{
                withName: '.*SPATIAL_QC_POSTFILTER.*:GENERAL_QC:QC_IMAGE_DIM_PLOT' {
                    ext.args = {
                        [
                            '--group_by BiologicalGroup'
                        ].join(' ').trim()
                    }
                    publishDir = [
                        path: { "${params.outdir}/compiled/filtered/qc" },
                        mode: params.publish_dir_mode,
                        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                    ]
                }
            }
        }

        if (!params.skip_post_general_vln_plot) {
            process {
                withName: '.*SPATIAL_QC_POSTFILTER.*:GENERAL_QC:QC_VLN_PLOT' {
                    ext.args = {
                        [
                            '--features "nCount_Xenium,nFeature_Xenium"',
                            '--ncols_vln 2'
                        ].join(' ').trim()
                    }
                    publishDir = [
                        path: { "${params.outdir}/compiled/filtered/qc" },
                        mode: params.publish_dir_mode,
                        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                    ]
                }
            }
        }

        if (!params.skip_post_general_scatter_plot) {
            process {
                withName: '.*SPATIAL_QC_POSTFILTER.*:GENERAL_QC:QC_FEATURE_SCATTER_PLOT' {
                    ext.args = {
                        [
                            '--feature1 nCount_Xenium',
                            '--feature2 nFeature_Xenium',
                        ].join(' ').trim()
                    }
                    publishDir = [
                        path: { "${params.outdir}/compiled/filtered/qc" },
                        mode: params.publish_dir_mode,
                        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                    ]
                }
            }
        }

        if (!params.skip_post_general_nfeature_plot) {
            process {
                withName: '.*SPATIAL_QC_POSTFILTER.*:GENERAL_QC:QC_IFP_NFEATURE' {
                    ext.prefix = { "${meta.id}.qc_nfeature" }
                    ext.args = {
                        [
                            '--features "nFeature_Xenium"'
                        ].join(' ').trim()
                    }
                    publishDir = [
                        path: { "${params.outdir}/compiled/filtered/qc" },
                        mode: params.publish_dir_mode,
                        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                    ]
                }
            }
        }

        if (!params.skip_post_general_ncount_plot) {
            process {
                withName: '.*SPATIAL_QC_POSTFILTER.*:GENERAL_QC:QC_IFP_NCOUNT' {
                    ext.prefix = { "${meta.id}.qc_ncount" }
                    ext.args = {
                        [
                            '--features "nCount_Xenium"'
                        ].join(' ').trim()
                    }
                    publishDir = [
                        path: { "${params.outdir}/compiled/filtered/qc" },
                        mode: params.publish_dir_mode,
                        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                    ]
                }
            }
        }
    }

    /****************************
    * CELL AREA QC SUBWORKFLOW *
    ****************************/

    if (!params.skip_pre_cell_area_qc) {
        if (!params.skip_pre_area_histogram_plot) {
            process {
                withName: '.*SPATIAL_QC_PREFILTER.*:QC_HISTOGRAM_PLOT' {
                    publishDir = [
                        path: { "${params.outdir}/compiled/raw_data/qc/cell_area_qc" },
                        mode: params.publish_dir_mode,
                        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                    ]
                }
            }
        }

        process {
            withName: '.*SPATIAL_QC_PREFILTER.*:CALCULATE_OUTLIERS' {
                publishDir = [ 
                    enabled: false
                ]
            }
        }

        process {
            withName: '.*SPATIAL_QC_PREFILTER.*:COMPILE_OUTLIER_DF' {
                publishDir = [ 
                    enabled: false
                ]
            }
        }

        if (!params.skip_pre_area_box_plot) {
            process {
                withName: '.*SPATIAL_QC_PREFILTER.*:QC_BOX_PLOT' {
                    publishDir = [
                        path: { "${params.outdir}/compiled/raw_data/qc/cell_area_qc" },
                        mode: params.publish_dir_mode,
                        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                    ]
                }
            }
        }

        if (!params.skip_pre_area_overlap_histogram_plot) {
            process {
                withName: '.*SPATIAL_QC_PREFILTER.*:QC_OVERLAPPING_HISTOGRAM_PLOT' {
                    publishDir = [
                        path: { "${params.outdir}/compiled/raw_data/qc/cell_area_qc" },
                        mode: params.publish_dir_mode,
                        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                    ]
                }
