/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

}


process{
    withName: '.*:CREATE_XENIUM_OBJ' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/raw_data/" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}

process{
    withName: '.*:ADD_METADATA' {
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:ADD_TISSUE_COORDS' {
        publishDir = [
            enabled: false
        ]
    }
}

process {
    withName: '.*:MERGE_XENIUM_OBJECTS' {
        publishDir = [
            enabled: false
        ]
    }
}

if (!params.skip_banksy_vf_filter) {
    process {
        withName: '.*:FIND_VARIABLE_FEATURES' {
            ext.args = [
                "--nfeatures ${params.vf_nfeatures}"
            ].join(' ').trim()
            publishDir = [
                enabled: false
            ]
        }
    }
}

process {
    withName: '.*:SUBSET_VARIABLE_FEATURES' {
        ext.args = {
            [
                params.gene_whitelist ? "--whitelist ${params.gene_whitelist}" : ""
            ].join(' ').trim()
        }
        publishDir = [
            enabled: false
        ]
    }
}

/**************************************
 * ADD_MANUAL_ANNOTATIONS SUBWORKFLOW *
 **************************************/

process{
    withName: '.*:ADD_MANUAL_ANNOTATIONS' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/manual_annotations/" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}

if (!params.skip_qc && !params.skip_man_ann_dim_plot) {
    process{
        withName: '.*:MANUAL_ANNOTATION_IMG_DIM_PLOT' {
            ext.args = {
                [
                    '--group_by Tissue_annotation'
                ].join(' ').trim()
            }
            publishDir = [
                path: { "${params.outdir}/compiled/manual_annotations/qc" },
                mode: params.publish_dir_mode,
                saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
            ]
        }
    }
}

process {
    withName: '.*:COMPILE_MANUAL_ANNOTATIONS' {
        publishDir = [ 
            enabled: false
        ]
    }
}

if (!params.skip_qc) {
    /************************************
    * MARKER_GENE_PAIRS_QC SUBWORKFLOW *
    ************************************/
    if (!params.skip_pre_marker_gene_qc) {
        process {
            withName: '.*SPATIAL_QC_PREFILTER.*:MARKER_GENE_PAIRS_QC:IDENTIFY_VARIABLE_GENES' {
                publishDir = [ 
                    enabled: false
                ]
            }
        }

        process {
            withName: '.*SPATIAL_QC_PREFILTER.*:MARKER_GENE_PAIRS_QC:COMPILE_LISTS' {
                publishDir = [ 
                    enabled: false
                ]
            }   
        }

        process {
            withName: '.*SPATIAL_QC_PREFILTER.*:MARKER_GENE_PAIRS_QC:GENERATE_GENE_PAIR_STATS' {
                publishDir = [
                    path: { "${params.outdir}/${meta.id}/raw_data/qc/gene_pair_qc" },
                    mode: params.publish_dir_mode,
                    saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                ]
            }
        }

        process {
            withName: '.*SPATIAL_QC_PREFILTER.*:MARKER_GENE_PAIRS_QC:FILTER_GENE_PAIRS' {
                publishDir = [
                    path: { "${params.outdir}/${meta.id}/raw_data/qc/gene_pair_qc" },
                    mode: params.publish_dir_mode,
                    saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                ]
            }
        }
        if (!params.skip_pre_marker_barnyard_plot) {
            process {
                withName: '.*SPATIAL_QC_PREFILTER.*:MARKER_GENE_PAIRS_QC:QC_BARNYARD_PLOT' {
                    publishDir = [
                        path: { "${params.outdir}/${meta.id}/raw_data/qc/gene_pair_qc/barnyard_plot" },
                        mode: params.publish_dir_mode,
                        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                    ]
                }
            }
        }
    }

    if (!params.skip_post_marker_gene_qc) {
        process {
            withName: '.*SPATIAL_QC_POSTFILTER.*:MARKER_GENE_PAIRS_QC:IDENTIFY_VARIABLE_GENES' {
                publishDir = [ 
                    enabled: false
                ]
            }
        }

        process {
            withName: '.*SPATIAL_QC_POSTFILTER.*:MARKER_GENE_PAIRS_QC:COMPILE_LISTS' {
                publishDir = [ 
                    enabled: false
                ]
            }   
        }

        process {
            withName: '.*SPATIAL_QC_POSTFILTER.*:MARKER_GENE_PAIRS_QC:GENERATE_GENE_PAIR_STATS' {
                publishDir = [
                    path: { "${params.outdir}/${meta.id}/filtered/qc/gene_pair_qc" },
                    mode: params.publish_dir_mode,
                    saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                ]
            }
        }

        process {
            withName: '.*SPATIAL_QC_POSTFILTER.*:MARKER_GENE_PAIRS_QC:DETERMINE_MUTEX_GENE_PAIRS' {
                publishDir = [
                    path: { "${params.outdir}/${meta.id}/filtered/qc/gene_pair_qc" },
                    mode: params.publish_dir_mode,
                    saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                ]
            }
        }

        if (!params.skip_post_marker_barnyard_plot) {
            process {
                withName: '.*SPATIAL_QC_POSTFILTER.*:MARKER_GENE_PAIRS_QC:QC_BARNYARD_PLOT' {
                    publishDir = [
                        path: { "${params.outdir}/${meta.id}/filtered/qc/gene_pair_qc/barnyard_plot" },
                        mode: params.publish_dir_mode,
                        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                    ]
                }
            }
        }
    }


    /*****************************
    * CELL_SHAPE_QC SUBWORKFLOW *
    *****************************/

    if (!params.skip_pre_cell_shape_qc) {
        process {
            withName: '.*SPATIAL_QC_PREFILTER.*:CLASSIFY_CELL_SHAPE' {
                publishDir = [
                    path: { "${params.outdir}/${meta.id}/raw_data/qc/cell_shape_qc/" },
                    mode: params.publish_dir_mode,
                    saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
                ]
            }
        }

        if (!params.skip_pre_cell_shape_prop_plot) {
            process {
                withName: '.*SPATIAL_QC_PREFILTER.*:CELL_SHAPE_PLOT' {
                    ext.prefix = { "${meta.id}.cell_shape"}
                    publishDir = [
                        path: { "${params.outdir}/compiled/raw_data/qc/cell_shape_qc/" },
